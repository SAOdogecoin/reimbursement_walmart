generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model SettlementClaim {
  id                  String   @id @default(uuid())
  merchantName        String
  transactionType     String
  reasonCode          String?
  wfsReferenceId      String
  walmartPoNumber     String?
  partnerGtin         String?
  quantity            Int      @default(1)
  netPayable          Float
  transactionDateTime DateTime
  createdAt           DateTime @default(now())

  @@unique([wfsReferenceId, transactionDateTime, netPayable, merchantName])
}
